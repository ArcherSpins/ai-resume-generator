generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  avatar          String?
  templateCredits Int      @default(10)
  voiceCredits    Int      @default(5)
  createdAt       DateTime @default(now())
  resumes         Resume[]
}

model Resume {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schema    Json?
  data      Json?
  filePath  String?
  createdAt DateTime @default(now())

  @@index([userId])
}
